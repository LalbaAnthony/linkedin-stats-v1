# linkedin-stats optional environment configuration.
# Copy this file to ".env" and adjust values. All variables are optional;
# defaults are applied when a variable is missing.

# Run the browser without a visible window. Accepts: 1/true/yes for headless.
# Note: the FIRST run must be non-headless so you can log in manually.
LINKEDIN_HEADLESS=false

# Where the persisted Playwright session (cookies/storage) is stored.
# Relative paths are resolved from the project root.
LINKEDIN_SESSION_PATH=sessions/linkedin.json

# Default CSV output path. The --output CLI flag overrides this per run.
LINKEDIN_OUTPUT_PATH=output/results.csv

# Random human-like delay bounds (in seconds) between browser actions.
LINKEDIN_MIN_DELAY=1.0
LINKEDIN_MAX_DELAY=2.5

# Scraping limits. For a date range far in the past on an active company feed,
# raise LINKEDIN_MAX_FEED_SCROLLS so the scraper can scroll back far enough to
# reach old posts (the feed loads newest-first).
LINKEDIN_MAX_FEED_SCROLLS=60
LINKEDIN_MAX_MODAL_SCROLLS=80
LINKEDIN_SCROLL_PAUSE_MS=1200

# How long (ms) to wait for the manual login on first run.
LINKEDIN_LOGIN_TIMEOUT_MS=180000
